TMIS_ENVIRONMENT=development
TMIS_DEBUG=true

TMIS_DATABASE_URL=postgresql+psycopg://tmis:tmis@localhost:5432/tmis
TMIS_REDIS_URL=redis://localhost:6379/0
TMIS_QDRANT_URL=http://localhost:6333

# TMIS_DEBUG=true above lets this short local-only placeholder pass
# startup; outside debug mode a secret under 32 chars refuses to start
# (see tmis.core.config.Settings and docs/07-strategie-securite.md).
# In staging/production, generate a real secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
TMIS_JWT_SECRET_KEY=dev-only-not-for-production

# Same rule as the JWT secret above: `TMIS_DEBUG=true` tolerates these
# placeholder defaults; outside debug mode, leaving either at
# "change-me-in-production" (or blank) refuses to start (see
# tmis.core.config.Settings and docs/07-strategie-securite.md).
TMIS_LICENSE_SIGNING_KEY=change-me-in-production
TMIS_PLUGIN_SIGNING_KEY=change-me-in-production

TMIS_DEFAULT_MODEL_PROVIDER=openai
